/* ═══════════════════════════════════════════════════════════════════════════
   GOLDPOT — Mini Game Engine (Coin Tap) v2
   ═══════════════════════════════════════════════════════════════════════════ */

class GoldPotGame {
  constructor(canvas) {
    this.canvas = canvas;
    this.ctx = canvas.getContext('2d');
    this.running = false;
    this.score = 0;
    this.timeLeft = 10;
    this.coins = [];
    this.particles = [];
    this.ripples = [];
    this.combo = 0;
    this.comboTimer = 0;
    this.spawnRate = 800;
    this.lastSpawn = 0;
    this.animFrame = null;
    this.onScore = null;
    this.onEnd = null;
    this.onTick = null;
    this.onCombo = null;
    this.startTime = 0;
    this.dpr = window.devicePixelRatio || 1;
    this.powerups = [];
    this.freezeTimer = 0;
    this.frenzyTimer = 0;

    this._resize();
    this._bindEvents();
  }

  _resize() {
    const rect = this.canvas.parentElement.getBoundingClientRect();
    this.w = rect.width;
    this.h = rect.height;
    this.canvas.width = this.w * this.dpr;
    this.canvas.height = this.h * this.dpr;
    this.canvas.style.width = this.w + 'px';
    this.canvas.style.height = this.h + 'px';
    this.ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
  }

  _bindEvents() {
    const handler = (e) => {
      if (!this.running) return;
      e.preventDefault();
      const rect = this.canvas.getBoundingClientRect();
      const touches = e.changedTouches ? Array.from(e.changedTouches) : [e];
      for (const t of touches) {
        const x = (t.clientX || t.pageX) - rect.left;
        const y = (t.clientY || t.pageY) - rect.top;
        this._handleTap(x, y);
      }
    };
    this.canvas.addEventListener('mousedown', handler);
    this.canvas.addEventListener('touchstart', handler, { passive: false });
    window.addEventListener('resize', () => this._resize());
  }

  _handleTap(x, y) {
    let hit = false;

    // Check powerups
    for (let i = this.powerups.length - 1; i >= 0; i--) {
      const pu = this.powerups[i];
      const dx = x - pu.x, dy = y - pu.y;
      if (dx * dx + dy * dy < pu.r * pu.r) {
        this._activatePowerup(pu);
        this.powerups.splice(i, 1);
        this._spawnParticles(pu.x, pu.y, '#60ffe0', 15);
        return;
      }
    }

    for (let i = this.coins.length - 1; i >= 0; i--) {
      const c = this.coins[i];
      const dx = x - c.x, dy = y - c.y;
      if (dx * dx + dy * dy < c.r * c.r) {
        hit = true;
        this.combo++;
        this.comboTimer = 60;

        let points = c.golden ? 5 : 1;
        if (this.combo >= 10) points *= 3;
        else if (this.combo >= 5) points *= 2;
        if (this.frenzyTimer > 0) points *= 2;

        this.score += points;
        this._spawnParticles(c.x, c.y, c.golden ? '#ffe066' : '#f0c040', c.golden ? 20 : 10);
        this._spawnRipple(c.x, c.y, c.golden);

        const comboText = this.combo >= 10 ? ' 💥x' + this.combo : this.combo >= 5 ? ' 🔥x' + this.combo : this.combo >= 3 ? ' x' + this.combo : '';
        this.particles.push({
          x: c.x, y: c.y - 10, vx: 0, vy: -2, life: 40, maxLife: 40, type: 'text',
          text: '+' + points + comboText, color: c.golden ? '#ffe066' : '#f0c040', size: points >= 10 ? 24 : c.golden ? 20 : 16,
        });

        this.coins.splice(i, 1);
        if (this.onScore) this.onScore(this.score);
        if (this.combo >= 5 && this.onCombo) this.onCombo(this.combo);
        break;
      }
    }

    if (!hit) {
      this.combo = 0;
      this._spawnRipple(x, y, false, '#ff4060');
    }
  }

  _activatePowerup(pu) {
    if (pu.type === 'freeze') {
      this.freezeTimer = 180; // 3 seconds at 60fps
      this.particles.push({ x: this.w / 2, y: this.h / 2, vx: 0, vy: -1, life: 60, maxLife: 60, type: 'text', text: '❄️ TIME FREEZE!', color: '#60c0ff', size: 24 });
    } else if (pu.type === 'frenzy') {
      this.frenzyTimer = 300; // 5 seconds
      this.particles.push({ x: this.w / 2, y: this.h / 2, vx: 0, vy: -1, life: 60, maxLife: 60, type: 'text', text: '⚡ 2x FRENZY!', color: '#ff8040', size: 24 });
    } else if (pu.type === 'bomb') {
      const points = this.coins.length * 2;
      this.score += points;
      for (const c of this.coins) this._spawnParticles(c.x, c.y, '#ff6060', 8);
      this.coins = [];
      this.particles.push({ x: this.w / 2, y: this.h / 2, vx: 0, vy: -1, life: 60, maxLife: 60, type: 'text', text: '💣 BOOM +' + points, color: '#ff6060', size: 24 });
      if (this.onScore) this.onScore(this.score);
    }
  }

  _spawnParticles(x, y, color, count) {
    for (let i = 0; i < count; i++) {
      const angle = (Math.PI * 2 * i) / count + Math.random() * 0.5;
      const speed = 2 + Math.random() * 4;
      this.particles.push({ x, y, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed, life: 30 + Math.random() * 20, maxLife: 50, type: 'dot', color, size: 3 + Math.random() * 4 });
    }
  }

  _spawnRipple(x, y, golden, color) {
    this.ripples.push({ x, y, r: 10, maxR: golden ? 80 : 50, life: 20, maxLife: 20, color: color || (golden ? '#ffe066' : '#f0c040') });
  }

  _spawnCoin() {
    const r = 22 + Math.random() * 16;
    const golden = Math.random() < 0.12;
    this.coins.push({
      x: r + Math.random() * (this.w - r * 2), y: -r, r,
      vy: 1.5 + Math.random() * 2, vx: (Math.random() - 0.5) * 1.5,
      rotation: Math.random() * Math.PI * 2, rotSpeed: (Math.random() - 0.5) * 0.1,
      golden, wobble: Math.random() * Math.PI * 2, wobbleSpeed: 0.03 + Math.random() * 0.03,
    });
  }

  _spawnPowerup() {
    const types = ['freeze', 'frenzy', 'bomb'];
    const type = types[Math.floor(Math.random() * types.length)];
    const icons = { freeze: '❄️', frenzy: '⚡', bomb: '💣' };
    this.powerups.push({
      x: 30 + Math.random() * (this.w - 60), y: -20, r: 20,
      vy: 1 + Math.random(), type, icon: icons[type], life: 0,
    });
  }

  start() {
    this.running = true;
    this.score = 0;
    this.timeLeft = 10;
    this.coins = [];
    this.particles = [];
    this.ripples = [];
    this.powerups = [];
    this.combo = 0;
    this.freezeTimer = 0;
    this.frenzyTimer = 0;
    this.startTime = performance.now();
    this.lastSpawn = 0;
    this._resize();
    this._loop(performance.now());
  }

  stop() {
    this.running = false;
    if (this.animFrame) cancelAnimationFrame(this.animFrame);
  }

  _loop(now) {
    if (!this.running) return;

    const elapsed = now - this.startTime;
    // Freeze slows time
    if (this.freezeTimer > 0) {
      this.startTime += 8; // slow down clock
      this.freezeTimer--;
    }
    if (this.frenzyTimer > 0) this.frenzyTimer--;

    this.timeLeft = Math.max(0, 10 - (now - this.startTime) / 1000);
    if (this.onTick) this.onTick(this.timeLeft);

    this.spawnRate = Math.max(200, 700 - (now - this.startTime) * 0.05);

    if (now - this.lastSpawn > this.spawnRate) {
      this._spawnCoin();
      if ((now - this.startTime) > 3000 && Math.random() < 0.4) this._spawnCoin();
      if ((now - this.startTime) > 6000 && Math.random() < 0.3) this._spawnCoin();
      // Powerup chance
      if (Math.random() < 0.06) this._spawnPowerup();
      this.lastSpawn = now;
    }

    this._update();
    this._draw();

    if (this.timeLeft <= 0) {
      this.running = false;
      if (this.onEnd) this.onEnd(this.score);
      return;
    }
    this.animFrame = requestAnimationFrame((t) => this._loop(t));
  }

  _update() {
    for (let i = this.coins.length - 1; i >= 0; i--) {
      const c = this.coins[i];
      c.y += c.vy; c.x += c.vx + Math.sin(c.wobble) * 0.5; c.wobble += c.wobbleSpeed; c.rotation += c.rotSpeed;
      if (c.x < c.r) { c.x = c.r; c.vx = Math.abs(c.vx); }
      if (c.x > this.w - c.r) { c.x = this.w - c.r; c.vx = -Math.abs(c.vx); }
      if (c.y > this.h + c.r) { this.coins.splice(i, 1); this.combo = 0; }
    }
    for (let i = this.powerups.length - 1; i >= 0; i--) {
      const pu = this.powerups[i];
      pu.y += pu.vy; pu.life++;
      if (pu.y > this.h + 30) this.powerups.splice(i, 1);
    }
    for (let i = this.particles.length - 1; i >= 0; i--) {
      const p = this.particles[i];
      p.x += p.vx; p.y += p.vy;
      if (p.type === 'dot') p.vy += 0.1;
      p.life--;
      if (p.life <= 0) this.particles.splice(i, 1);
    }
    for (let i = this.ripples.length - 1; i >= 0; i--) {
      const r = this.ripples[i];
      r.r += (r.maxR - r.r) * 0.15; r.life--;
      if (r.life <= 0) this.ripples.splice(i, 1);
    }
    if (this.comboTimer > 0) this.comboTimer--; else this.combo = Math.max(0, this.combo - 1);
  }

  _draw() {
    const ctx = this.ctx;
    ctx.clearRect(0, 0, this.w, this.h);

    // Background
    const grad = ctx.createLinearGradient(0, 0, 0, this.h);
    grad.addColorStop(0, this.frenzyTimer > 0 ? '#1a0a0a' : '#0a0a14');
    grad.addColorStop(1, this.frenzyTimer > 0 ? '#1a0808' : '#0f0f1e');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, this.w, this.h);

    // Freeze overlay
    if (this.freezeTimer > 0) {
      ctx.fillStyle = `rgba(96, 192, 255, ${0.05 + Math.sin(Date.now() * 0.005) * 0.03})`;
      ctx.fillRect(0, 0, this.w, this.h);
    }

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.02)';
    ctx.lineWidth = 1;
    for (let x = 0; x < this.w; x += 40) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, this.h); ctx.stroke(); }
    for (let y = 0; y < this.h; y += 40) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(this.w, y); ctx.stroke(); }

    // Ripples
    for (const r of this.ripples) {
      const alpha = r.life / r.maxLife;
      ctx.beginPath(); ctx.arc(r.x, r.y, r.r, 0, Math.PI * 2);
      ctx.strokeStyle = r.color + Math.floor(alpha * 80).toString(16).padStart(2, '0');
      ctx.lineWidth = 2; ctx.stroke();
    }

    // Coins
    for (const c of this.coins) {
      ctx.save(); ctx.translate(c.x, c.y); ctx.rotate(c.rotation);
      const glow = ctx.createRadialGradient(0, 0, c.r * 0.5, 0, 0, c.r + (c.golden ? 20 : 8));
      glow.addColorStop(0, c.golden ? 'rgba(255,224,102,0.4)' : 'rgba(240,192,64,0.2)');
      glow.addColorStop(1, 'transparent');
      ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(0, 0, c.r + (c.golden ? 20 : 8), 0, Math.PI * 2); ctx.fill();

      const cg = ctx.createRadialGradient(-c.r * 0.3, -c.r * 0.3, 0, 0, 0, c.r);
      if (c.golden) { cg.addColorStop(0, '#fff8d0'); cg.addColorStop(0.4, '#ffe066'); cg.addColorStop(1, '#c8941e'); }
      else { cg.addColorStop(0, '#ffe8a0'); cg.addColorStop(0.4, '#f0c040'); cg.addColorStop(1, '#a06810'); }
      ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(0, 0, c.r, 0, Math.PI * 2); ctx.fill();

      ctx.strokeStyle = c.golden ? 'rgba(255,255,255,0.4)' : 'rgba(255,255,255,0.2)';
      ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(0, 0, c.r * 0.7, 0, Math.PI * 2); ctx.stroke();

      ctx.fillStyle = c.golden ? '#a07000' : '#805000';
      ctx.font = `bold ${c.r * 0.9}px sans-serif`;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(c.golden ? '★' : '$', 0, 1);

      ctx.beginPath(); ctx.ellipse(-c.r * 0.2, -c.r * 0.3, c.r * 0.35, c.r * 0.15, -0.5, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,0.25)'; ctx.fill();
      ctx.restore();
    }

    // Powerups
    for (const pu of this.powerups) {
      ctx.save(); ctx.translate(pu.x, pu.y);
      // Glow
      ctx.shadowColor = pu.type === 'freeze' ? '#60c0ff' : pu.type === 'frenzy' ? '#ff8040' : '#ff4040';
      ctx.shadowBlur = 20;
      ctx.beginPath(); ctx.arc(0, 0, pu.r, 0, Math.PI * 2);
      ctx.fillStyle = pu.type === 'freeze' ? '#1a3050' : pu.type === 'frenzy' ? '#3a2010' : '#3a1010';
      ctx.fill();
      ctx.strokeStyle = pu.type === 'freeze' ? '#60c0ff' : pu.type === 'frenzy' ? '#ff8040' : '#ff4040';
      ctx.lineWidth = 2; ctx.stroke();
      ctx.shadowBlur = 0;
      ctx.font = '18px sans-serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(pu.icon, 0, 0);
      ctx.restore();
    }

    // Particles
    for (const p of this.particles) {
      const alpha = p.life / p.maxLife;
      if (p.type === 'dot') {
        ctx.beginPath(); ctx.arc(p.x, p.y, p.size * alpha, 0, Math.PI * 2);
        ctx.fillStyle = p.color + Math.floor(alpha * 255).toString(16).padStart(2, '0');
        ctx.fill();
      } else if (p.type === 'text') {
        ctx.font = `bold ${p.size}px sans-serif`;
        ctx.textAlign = 'center';
        ctx.fillStyle = p.color + Math.floor(alpha * 255).toString(16).padStart(2, '0');
        ctx.fillText(p.text, p.x, p.y);
      }
    }

    // Combo bar
    if (this.combo >= 3) {
      const barW = Math.min(this.combo * 12, this.w - 40);
      ctx.fillStyle = this.combo >= 10 ? 'rgba(255,96,64,0.3)' : 'rgba(255,200,64,0.2)';
      ctx.fillRect((this.w - barW) / 2, this.h - 10, barW, 6);
      ctx.font = 'bold 13px Inter, sans-serif'; ctx.textAlign = 'center';
      ctx.fillStyle = `rgba(255,224,102,${0.6 + Math.sin(Date.now() * 0.01) * 0.3})`;
      ctx.fillText(`${this.combo >= 10 ? '💥' : '🔥'} COMBO x${this.combo}`, this.w / 2, this.h - 18);
    }
  }
}

window.GoldPotGame = GoldPotGame;
